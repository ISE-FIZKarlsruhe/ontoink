# ontoink — production environment configuration
# Copy to `.env` and adjust for your deployment.

# ───────────────────────────────────────────────────────────────────────
# Mode: what the container does
#   serve  → MkDocs dev server (docs only, no /reason)
#   build  → run `mkdocs build` once and exit (CI / static export)
#   api    → FastAPI server with /reason and /validate (no docs)
#   all    → Combined: builds docs once, then FastAPI serves them at /
#            alongside /reason, /validate, /health. Same-origin endpoints
#            so the playground's "Server" reasoner option works without
#            a reverse proxy. Recommended for self-hosted production.
# ───────────────────────────────────────────────────────────────────────
ONTOINK_MODE=all

# ───────────────────────────────────────────────────────────────────────
# Reasoner backend
#   auto           → owlready2 → konclude (native) → konclude-wasm → owlrl
#   owlready2      → HermiT via owlready2 (Java required, included in image)
#   konclude       → native Konclude C++ binary, upstream from University of Ulm
#                    (https://github.com/konclude/Konclude)
#   konclude-wasm  → rdf-reasoner-konclude, WASM port for browsers and Node.js
#                    (https://github.com/ThHanke/rdf-reasoner-konclude)
#   owlrl          → pure-Python OWL-RL profile (fastest, weakest)
#   none           → skip reasoning entirely
# ───────────────────────────────────────────────────────────────────────
ONTOINK_REASONER=auto

# Override the native Konclude binary path (default: `konclude` on PATH)
# ONTOINK_KONCLUDE_BIN=konclude

# Override the WASM Konclude CLI name (default: `owl-reason` on PATH)
# ONTOINK_KONCLUDE_WASM_BIN=owl-reason

# HTTP port for serve/api modes
ONTOINK_PORT=8000

# Path inside the container where docs live (mounted via docker-compose)
ONTOINK_DOCS_DIR=/app/demo

# Where the container writes per-request reasoning runs (input.ttl, inferences.json,
# inferences.nt). Mount this as a volume in docker-compose to persist runs to the host.
# Set empty to disable persistence.
ONTOINK_OUTPUT_DIR=/output
