@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix sh:    <http://www.w3.org/ns/shacl#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix ap:    <http://ise.fiz-karlsruhe.de/ontoink/anti-patterns#> .

# AIO (Corcho/Roussey) -- intersection used for union
# Source bundle: demo/docs/anti-patterns/shacl-shapes.ttl

# AndIsOr (AIO) -- Corcho/Roussey 2009
#   C subClassOf  exists R.A  intersection  exists R.B
#   with Disjoint(A, B)
#
# The class is SATISFIABLE: any instance needs two distinct R-successors.
# The smell is intent: the modeller almost always meant
#   C subClassOf exists R.(A union B)
# i.e. "at least one of A or B", not "at least one of each".
#
ap:AndIsOrShape a sh:NodeShape ;
    sh:targetClass owl:Class ;
    sh:severity sh:Warning ;
    sh:sparql [
        sh:message "AIO (Corcho/Roussey): two existential restrictions on the same property with disjoint fillers; modeller probably meant a disjunction." ;
        sh:select """
            SELECT DISTINCT $this WHERE {
                $this <http://www.w3.org/2000/01/rdf-schema#subClassOf> ?r1, ?r2 .
                ?r1 a <http://www.w3.org/2002/07/owl#Restriction> ;
                    <http://www.w3.org/2002/07/owl#onProperty> ?p ;
                    <http://www.w3.org/2002/07/owl#someValuesFrom> ?c1 .
                ?r2 a <http://www.w3.org/2002/07/owl#Restriction> ;
                    <http://www.w3.org/2002/07/owl#onProperty> ?p ;
                    <http://www.w3.org/2002/07/owl#someValuesFrom> ?c2 .
                { ?c1 <http://www.w3.org/2002/07/owl#disjointWith> ?c2 . }
                UNION
                { ?c2 <http://www.w3.org/2002/07/owl#disjointWith> ?c1 . }
                FILTER(?r1 != ?r2 && ?c1 != ?c2)
            }
        """ ;
    ] ;
    rdfs:seeAlso <https://liris.cnrs.fr/Documents/Liris-4441.pdf> .

#
