@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix sh:    <http://www.w3.org/ns/shacl#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix nfdicore: <https://nfdi.fiz-karlsruhe.de/ontology/> .

nfdicore:RoleBearerShape
    a sh:NodeShape ;
    sh:targetClass <http://purl.obolibrary.org/obo/BFO_0000023> ;
    sh:property [
        sh:path <http://purl.obolibrary.org/obo/RO_0000081> ;
        sh:minCount 1 ;
        sh:message "A role must always be a role_of something."
    ] ;
    sh:property [
        sh:path <http://purl.obolibrary.org/obo/BFO_0000054> ;
        sh:minCount 1 ;
        sh:message "A role must always be realized in some process."
    ] ;
    .
